---
interface Props {
  href: string
  text: string
}
const { href, text } = Astro.props
---

<a
  class="bg-light-bg hover:bg-dark-bg hover:text-dark-fg dark:bg-dark-bg dark:hover:bg-light-bg dark:hover:text-light-fg transition-colors motion-reduce:transition-none motion-reduce:hover:transform-none duration-500"
  href={href}>{`[ ${text} ]`}</a
>
