---
interface Props {
  href: string
  text: string
}
const { href, text } = Astro.props
---

<a
  class="bg-white dark:bg-black
  hover:bg-black dark:hover:bg-white
  hover:text-white dark:hover:text-black
  transition-colors motion-reduce:transition-none motion-reduce:hover:transform-none duration-500"
  href={href}>{`[ ${text} ]`}</a
>
